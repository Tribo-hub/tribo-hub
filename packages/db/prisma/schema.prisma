// Tribo Hub — schema Prisma v4
// Plataforma SaaS bimodal: Corporativo (B2B) + Infoprodutor (B2B2C / área de membros)
// Regra de ouro: TODA query de dados de tenant filtra por contaId. Sem exceção.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum TipoConta {
  corporativo
  infoprodutor
}

enum Role {
  super_admin // operação da plataforma (você)
  admin_tenant // gestor (corporativo) ou produtor (infoprodutor)
  aluno // colaborador (corporativo) ou comprador (infoprodutor)
}

enum ProprietarioConteudo {
  plataforma // catálogo global (modo corporativo)
  tenant // conteúdo do infoprodutor (isolado por contaId)
}

enum CategoriaTrilha {
  vendas
  lideranca
  atendimento
  comunicacao
  produtividade
  outros
}

enum TipoVideo {
  upload
  youtube
  vimeo
}

enum PlataformaExterna {
  hotmart
  eduzz
  kiwify
  manual
}

enum TipoAcesso {
  prazo
  vitalicio
}

enum OrigemMatricula {
  compra
  cortesia
  manual
}

enum StatusMatricula {
  ativa
  inativa // desativada pelo produtor
  expirada // prazo vencido
}

enum StatusTransacao {
  aprovada
  reembolsada
  chargeback
  cancelada
}

enum TipoCobranca {
  assentos // corporativo
  alunos_ativos // infoprodutor
}

enum StatusAssinatura {
  ativa
  suspensa
  cancelada
}

// ============================================================
// TENANT
// ============================================================

model Conta {
  id             String    @id @default(uuid())
  nome           String
  tipoConta      TipoConta
  cnpj           String?
  logoUrl        String?
  corPrimaria    String? // hex, ex: #1B3A6B
  slug           String    @unique
  subdominio     String    @unique
  dominioProprio String?   @unique
  ativo          Boolean   @default(true)
  permiteAutoCadastro Boolean @default(false) // infoprodutor: aluno pode se auto-cadastrar
  permiteComentarios  Boolean @default(true) // comentários por aula (engajamento) — liga/desliga por conta
  sessaoUnica         Boolean @default(false) // anti-compartilhamento: 1 sessão ativa por usuário
  boasVindasAtivo     Boolean @default(false) // exibe modal de boas-vindas no app do aluno
  mensagemBoasVindas  String? // conteúdo (HTML) do modal de boas-vindas
  agendaAtiva         Boolean @default(false) // Onda C: agenda de eventos ao vivo (lives)
  planosAtivos        Boolean @default(false) // Onda D: planos de ação (accountability)
  gamificacaoAtiva    Boolean @default(false) // Onda E: XP, níveis e badges
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  usuarios      Usuario[]
  trilhas       Trilha[] // somente conteúdo proprietarioTipo = tenant
  inviteTokens  InviteToken[]
  progresso     Progresso[]
  certificados  Certificado[]
  ofertas       Oferta[]
  matriculas    Matricula[]
  transacoes    Transacao[]
  integracoes   Integracao[]
  webhookEvents WebhookEvent[]
  assinatura    AssinaturaPlataforma?
  faturas       FaturaPlataforma[]

  @@map("contas")
}

// ============================================================
// USUÁRIOS
// ============================================================

model Usuario {
  id               String    @id @default(uuid())
  contaId          String? // nulo apenas para super_admin
  nome             String
  email            String // lowercase; único por conta (ver @@unique)
  telefone         String?
  sessaoAtual      String? // id da sessão ativa (anti-compartilhamento)
  senhaHash        String
  role             Role
  ativo            Boolean   @default(true)
  avatarUrl        String?
  ultimoAcesso     DateTime?
  tentativasFalhas Int       @default(0)
  bloqueadoAte     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  conta        Conta?        @relation(fields: [contaId], references: [id])
  progresso    Progresso[]
  certificados Certificado[]
  matriculas   Matricula[]
  transacoes   Transacao[]

  @@unique([contaId, email])
  @@index([contaId])
  @@map("usuarios")
}

// ============================================================
// CONTEÚDO: Trilha -> Modulo -> Aula
// ============================================================

model Trilha {
  id               String               @id @default(uuid())
  titulo           String
  descricao        String
  categoria        CategoriaTrilha?
  capaUrl          String?
  publicado        Boolean              @default(false)
  ordem            Int?
  proprietarioTipo ProprietarioConteudo @default(tenant)
  contaId          String? // nulo quando proprietarioTipo = plataforma
  // Vitrine/oferta: exibir esta trilha (trancada) para alunos de outras trilhas
  exibirComoOferta  Boolean @default(false)
  ofertaTodosAlunos Boolean @default(false) // aparece para qualquer aluno da conta
  ofertaParaTrilhas Json? // ids das trilhas cujos alunos veem esta como oferta
  checkoutUrl       String? // link de compra/checkout
  whatsappUrl       String? // link/numero de WhatsApp para falar com o produtor
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  conta        Conta?        @relation(fields: [contaId], references: [id])
  modulos      Modulo[]
  ofertas      Oferta[]
  matriculas   Matricula[]
  certificados Certificado[]

  @@index([contaId])
  @@index([proprietarioTipo])
  @@map("trilhas")
}

model Modulo {
  id        String    @id @default(uuid())
  trilhaId  String
  titulo    String
  descricao String?
  ordem     Int
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  trilha Trilha @relation(fields: [trilhaId], references: [id])
  aulas  Aula[]

  @@index([trilhaId])
  @@map("modulos")
}

model Aula {
  id              String     @id @default(uuid())
  moduloId        String
  titulo          String
  descricao       String?
  tipoVideo       TipoVideo? // opcional: aula pode ser só de texto
  videoUrl        String?
  videoIdExterno  String?
  duracaoSegundos Int        @default(0)
  conteudoTexto   String? // bloco de conteúdo em texto/HTML (LMS+)
  liberaAposDias  Int        @default(0) // drip content: libera N dias após início do acesso
  anexos          Json? // materiais complementares: [{ nome, path }]
  materialUrl     String?
  legendaUrl      String?
  ordem           Int
  publicado       Boolean    @default(false)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  modulo      Modulo           @relation(fields: [moduloId], references: [id])
  progresso   Progresso[]
  perguntas   QuizPergunta[]
  comentarios ComentarioAula[]

  @@index([moduloId])
  @@map("aulas")
}

// Comentários por aula (alunos comentam; produtor responde/modera). Thread de 1 nível via respostaAId.
model ComentarioAula {
  id          String    @id @default(uuid())
  aulaId      String
  usuarioId   String
  contaId     String
  texto       String
  respostaAId String? // resposta a outro comentário
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  aula      Aula             @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  respostaA ComentarioAula?  @relation("RespostasComentario", fields: [respostaAId], references: [id], onDelete: Cascade)
  respostas ComentarioAula[] @relation("RespostasComentario")

  @@index([aulaId])
  @@map("comentarios_aula")
}

// Onda C — eventos ao vivo (lives Zoom/Meet) por conta. trilhaId opcional restringe a audiência.
model EventoAoVivo {
  id         String   @id @default(uuid())
  contaId    String
  trilhaId   String? // null = todos os alunos da conta
  titulo     String
  descricao  String?
  linkAcesso String
  inicioEm   DateTime
  duracaoMin Int      @default(60)
  createdAt  DateTime @default(now())

  @@index([contaId])
  @@map("eventos_ao_vivo")
}

// Onda D — planos de ação (accountability de mentoria). Plano -> itens; aluno marca progresso.
model PlanoAcao {
  id           String    @id @default(uuid())
  contaId      String
  trilhaId     String? // null = todos os alunos da conta (audiência)
  moduloId     String? // escopo organizacional opcional (contexto)
  titulo       String
  subtitulo    String? // subtítulo temático (ex: "Ajuste de velas")
  descricao    String?
  capaUrl      String? // caminho da capa no Storage (estilo card)
  ordem        Int       @default(1) // nº sequencial do plano (#1, #2…)
  prazoEm      DateTime? // prazo de entrega do plano (deadline)
  releasedAt   DateTime? // data de liberação ao aluno (antes disso: bloqueado)
  analiseAtiva Boolean   @default(false) // mentor decide se este plano terá análise escrita
  createdAt    DateTime  @default(now())

  itens    PlanoItem[]
  entregas PlanoEntrega[]

  @@index([contaId])
  @@map("planos_acao")
}

enum PlanoItemTipo {
  check // marcar concluído
  assistir // assistir uma aula (conclui ao concluir a aula)
  resumo // assistir uma aula e escrever um resumo
  link // aluno entrega uma ou mais URLs (ex: Google Drive)
}

model PlanoItem {
  id        String        @id @default(uuid())
  planoId   String
  titulo    String
  descricao String? // instruções (texto + links)
  tipo      PlanoItemTipo @default(check)
  aulaId    String? // aula vinculada (tipos assistir/resumo)
  prazoEm   DateTime?
  ordem     Int           @default(1)
  createdAt DateTime      @default(now())

  plano     PlanoAcao            @relation(fields: [planoId], references: [id], onDelete: Cascade)
  progresso PlanoItemProgresso[]

  @@index([planoId])
  @@map("plano_itens")
}

model PlanoItemProgresso {
  id          String    @id @default(uuid())
  itemId      String
  usuarioId   String
  contaId     String
  concluido   Boolean   @default(false)
  texto       String? // resumo enviado pelo aluno (tipo resumo)
  links       Json? // URLs entregues pelo aluno (tipo link)
  concluidoEm DateTime?
  updatedAt   DateTime  @updatedAt

  item PlanoItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, usuarioId])
  @@index([itemId])
  @@map("plano_item_progresso")
}

enum PlanoEntregaStatus {
  submitted // aluno entregou o plano (aguardando análise, se houver)
  reviewed // mentor registrou a análise
}

// Submissão do plano completo por aluno (gate de 100% + análise do mentor).
model PlanoEntrega {
  id               String             @id @default(uuid())
  planoId          String
  usuarioId        String
  contaId          String
  status           PlanoEntregaStatus @default(submitted)
  submittedAt      DateTime           @default(now())
  diasAntesDoPrazo Int? // prazo - submittedAt em dias (negativo = atraso)
  analiseTexto     String? // análise escrita do mentor
  analiseEm        DateTime?

  plano PlanoAcao @relation(fields: [planoId], references: [id], onDelete: Cascade)

  @@unique([planoId, usuarioId])
  @@index([planoId])
  @@map("plano_entregas")
}

// Onda E — eventos de XP (ledger idempotente). tipo+refId evita pontuar 2x a mesma ação.
model XpEvento {
  id        String   @id @default(uuid())
  usuarioId String
  contaId   String
  trilhaId  String? // trilha a que o ponto pertence (null = sem trilha, ex.: plano da conta)
  tipo      String // 'aula' | 'trilha' | 'plano_item' | 'quiz' | 'avaliacao' | 'comentario'
  refId     String
  xp        Int
  createdAt DateTime @default(now())

  @@unique([usuarioId, tipo, refId])
  @@index([contaId])
  @@index([usuarioId])
  @@index([trilhaId])
  @@map("xp_eventos")
}

// Config de gamificação por conta (produtor define os pontos do seu modelo). 1 por conta.
model ConfigGamificacao {
  contaId      String   @id
  xpAula       Int      @default(10)
  xpTrilha     Int      @default(100)
  xpPlanoItem  Int      @default(5)
  xpQuiz       Int      @default(0)
  xpAvaliacao  Int      @default(0)
  xpComentario Int      @default(0)
  xpPorNivel   Int      @default(200)
  // limiares dos badges fixos (só a quantidade é editável)
  badgeAulas1  Int      @default(1) // Primeiros passos
  badgeAulas2  Int      @default(10) // Maratonista
  badgeAulas3  Int      @default(50) // Dedicado
  badgeCert1   Int      @default(1) // Certificado!
  badgeCert2   Int      @default(3) // Colecionador
  badgeNivel   Int      @default(5) // Nível X
  updatedAt    DateTime @updatedAt

  @@map("config_gamificacao")
}

// Override da config de gamificação por trilha (quando ausente, usa a config da conta).
model ConfigGamificacaoTrilha {
  trilhaId     String   @id
  contaId      String
  xpAula       Int      @default(10)
  xpTrilha     Int      @default(100)
  xpPlanoItem  Int      @default(5)
  xpQuiz       Int      @default(0)
  xpAvaliacao  Int      @default(0)
  xpComentario Int      @default(0)
  xpPorNivel   Int      @default(200)
  badgeAulas1  Int      @default(1)
  badgeAulas2  Int      @default(10)
  badgeAulas3  Int      @default(50)
  badgeCert1   Int      @default(1)
  badgeCert2   Int      @default(3)
  badgeNivel   Int      @default(5)
  updatedAt    DateTime @updatedAt

  @@index([contaId])
  @@map("config_gamificacao_trilha")
}

// Quiz por aula (perguntas abertas; produtor vê as respostas dos alunos).
model QuizPergunta {
  id        String   @id @default(uuid())
  aulaId    String
  pergunta  String
  ordem     Int      @default(1)
  createdAt DateTime @default(now())

  aula      Aula          @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  respostas QuizResposta[]

  @@index([aulaId])
  @@map("quiz_perguntas")
}

model QuizResposta {
  id         String   @id @default(uuid())
  perguntaId String
  usuarioId  String
  contaId    String
  resposta   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pergunta QuizPergunta @relation(fields: [perguntaId], references: [id], onDelete: Cascade)

  @@unique([perguntaId, usuarioId])
  @@index([perguntaId])
  @@map("quiz_respostas")
}

// ============================================================
// PROGRESSO E CERTIFICADOS
// ============================================================

model Progresso {
  id                  String    @id @default(uuid())
  usuarioId           String
  aulaId              String
  contaId             String // redundante p/ queries multi-tenant eficientes
  concluido           Boolean   @default(false)
  percentualAssistido Decimal?  @db.Decimal(5, 2)
  avaliacao           Int? // nota da aula dada pelo aluno (1-5)
  concluidoEm         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  aula    Aula    @relation(fields: [aulaId], references: [id])
  conta   Conta   @relation(fields: [contaId], references: [id])

  @@unique([usuarioId, aulaId])
  @@index([contaId])
  @@map("progresso")
}

model Certificado {
  id                String   @id @default(uuid())
  usuarioId         String
  trilhaId          String
  contaId           String
  codigoVerificacao String   @unique // UUID v4
  pdfUrl            String?
  emitidoEm         DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  trilha  Trilha  @relation(fields: [trilhaId], references: [id])
  conta   Conta   @relation(fields: [contaId], references: [id])

  @@unique([usuarioId, trilhaId])
  @@index([contaId])
  @@map("certificados")
}

// ============================================================
// CONVITES (modo corporativo)
// ============================================================

model InviteToken {
  id        String   @id @default(uuid())
  email     String
  contaId   String
  role      Role
  token     String   @unique
  usado     Boolean  @default(false)
  expiraEm  DateTime
  createdAt DateTime @default(now())

  conta Conta @relation(fields: [contaId], references: [id])

  @@index([contaId])
  @@map("invite_tokens")
}

// ============================================================
// OFERTAS, MATRÍCULAS, TRANSAÇÕES (modo infoprodutor)
// ============================================================

model Oferta {
  id                   String            @id @default(uuid())
  contaId              String
  trilhaId             String
  nome                 String
  plataformaExterna    PlataformaExterna @default(hotmart)
  codigoProdutoExterno String? // id do produto na Hotmart/Eduzz/Kiwify
  tipoAcesso           TipoAcesso        @default(prazo)
  duracaoAcessoDias    Int? // null quando tipoAcesso = vitalicio
  ativo                Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  conta      Conta       @relation(fields: [contaId], references: [id])
  trilha     Trilha      @relation(fields: [trilhaId], references: [id])
  matriculas Matricula[]

  @@unique([contaId, plataformaExterna, codigoProdutoExterno])
  @@index([contaId])
  @@map("ofertas")
}

// Matrícula = vínculo aluno<->trilha e MEDIDOR DA COBRANÇA do infoprodutor.
model Matricula {
  id          String          @id @default(uuid())
  usuarioId   String
  trilhaId    String
  ofertaId    String?
  contaId     String
  origem      OrigemMatricula @default(compra)
  status      StatusMatricula @default(ativa)
  expiraEm    DateTime? // null = vitalício
  transacaoId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  trilha    Trilha     @relation(fields: [trilhaId], references: [id])
  oferta    Oferta?    @relation(fields: [ofertaId], references: [id])
  conta     Conta      @relation(fields: [contaId], references: [id])
  transacao Transacao? @relation(fields: [transacaoId], references: [id])

  @@unique([usuarioId, trilhaId])
  @@index([contaId, status]) // contagem de alunos ativos por conta
  @@index([expiraEm]) // job de expiração
  @@map("matriculas")
}

// Opcional: alimenta o dashboard de vendas do infoprodutor. NÃO é base da sua cobrança.
model Transacao {
  id                     String            @id @default(uuid())
  contaId                String
  ofertaId               String?
  usuarioId              String?
  plataformaExterna      PlataformaExterna
  codigoTransacaoExterno String            @unique
  valorBruto             Decimal           @db.Decimal(12, 2)
  status                 StatusTransacao   @default(aprovada)
  eventoEm               DateTime
  createdAt              DateTime          @default(now())

  conta      Conta       @relation(fields: [contaId], references: [id])
  usuario    Usuario?    @relation(fields: [usuarioId], references: [id])
  matriculas Matricula[]

  @@index([contaId])
  @@map("transacoes")
}

// ============================================================
// INTEGRAÇÕES E WEBHOOKS (modo infoprodutor)
// ============================================================

model Integracao {
  id            String            @id @default(uuid())
  contaId       String
  plataforma    PlataformaExterna
  webhookSecret String
  config        Json?
  ativo         Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  conta Conta @relation(fields: [contaId], references: [id])

  @@unique([contaId, plataforma])
  @@index([contaId])
  @@map("integracoes")
}

model WebhookEvent {
  id         String            @id @default(uuid())
  contaId    String?
  plataforma PlataformaExterna
  eventoTipo String
  hash       String            @unique // idempotência: não processar 2x
  payload    Json
  processado Boolean           @default(false)
  erro       String?
  createdAt  DateTime          @default(now())

  conta Conta? @relation(fields: [contaId], references: [id])

  @@index([contaId])
  @@map("webhook_events")
}

// ============================================================
// COBRANÇA DA PLATAFORMA (sua receita sobre o tenant)
// ============================================================

model AssinaturaPlataforma {
  id                String           @id @default(uuid())
  contaId           String           @unique
  plano             String // start | growth | scale | enterprise (corp) ou faixa infoprodutor
  tipoCobranca      TipoCobranca
  valorBase         Decimal          @db.Decimal(12, 2)
  // Corporativo:
  limiteUsuarios    Int?
  // Infoprodutor:
  alunosIncluidos   Int?
  valorPorExcedente Decimal?         @db.Decimal(12, 2)
  status            StatusAssinatura @default(ativa)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  conta Conta @relation(fields: [contaId], references: [id])

  @@map("assinaturas_plataforma")
}

// Histórico mensal apurado da cobrança.
model FaturaPlataforma {
  id             String   @id @default(uuid())
  contaId        String
  competencia    String // "YYYY-MM"
  alunosAtivos   Int? // infoprodutor
  assentosUsados Int? // corporativo
  valorBase      Decimal      @db.Decimal(12, 2)
  valorExcedente Decimal      @default(0) @db.Decimal(12, 2)
  valorTotal     Decimal      @db.Decimal(12, 2)
  status         StatusFatura @default(pendente)
  pagoEm         DateTime?
  txid           String? // id da cobrança Pix na Efí
  pixCopiaECola  String?
  fechadaEm      DateTime
  createdAt      DateTime     @default(now())

  conta Conta @relation(fields: [contaId], references: [id])

  @@unique([contaId, competencia])
  @@index([contaId])
  @@map("faturas_plataforma")
}

enum StatusFatura {
  pendente
  paga
  cancelada
}

// Token de redefinição de senha (vale para qualquer usuário, inclusive super_admin).
model PasswordResetToken {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  usado     Boolean  @default(false)
  expiraEm  DateTime
  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@map("password_reset_tokens")
}

// Agentes de IA (modo link externo): produtor/super admin cadastram link de GPT/Claude/etc.
model AgenteIA {
  id               String               @id @default(uuid())
  nome             String
  descricao        String?
  categoria        String?
  icone            String? // emoji
  url              String // link externo (abre em nova aba)
  proprietarioTipo ProprietarioConteudo @default(tenant) // plataforma (Super Admin, corporativo global) | tenant (produtor)
  contaId          String? // null quando plataforma
  todasTrilhas     Boolean              @default(false) // tenant: aparece em todas as trilhas da conta
  ativo            Boolean              @default(true)
  createdAt        DateTime             @default(now())

  trilhas AgenteTrilha[]

  @@index([contaId])
  @@map("agentes_ia")
}

model AgenteTrilha {
  agenteId String
  trilhaId String

  agente AgenteIA @relation(fields: [agenteId], references: [id], onDelete: Cascade)

  @@id([agenteId, trilhaId])
  @@map("agentes_ia_trilhas")
}

// Notificações do usuário (sino no header).
model Notificacao {
  id        String   @id @default(uuid())
  usuarioId String
  contaId   String?
  titulo    String
  mensagem  String
  tipo      String   @default("sistema") // matricula | certificado | convite | evento | sistema
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([usuarioId, lida])
  @@map("notificacoes")
}

// Atalhos configuráveis no menu lateral do Super Admin (abrem em nova aba).
model LinkMenuAdmin {
  id        String   @id @default(uuid())
  nome      String
  url       String
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("links_menu_admin")
}
