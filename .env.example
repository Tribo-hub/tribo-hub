# ============================================================
# TRIBO HUB — MODELO DE VARIÁVEIS DE AMBIENTE
# ------------------------------------------------------------
# Este arquivo é o MODELO (vai para o Git, SEM valores reais).
# Copie para `.env` e preencha os valores reais lá.
#   cp .env.example .env
# O `.env` real NUNCA vai para o Git (já está no .gitignore).
# A coluna [Fase] indica quando cada credencial passa a ser necessária.
# ============================================================

# ---------- APP / GERAL ---------- [Fase 0]
NODE_ENV=development
APP_BASE_DOMAIN=tribohub.com.br        # usado na resolução de tenant por subdomínio
APP_URL=http://localhost:3000          # frontend
API_URL=http://localhost:3333          # backend
NEXT_PUBLIC_API_URL=http://localhost:3333

# ---------- SEGREDOS DA APLICAÇÃO ---------- [Fase 1] (gerados localmente)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=
CRON_SECRET=                            # protege o endpoint do job de expiração
INTERNAL_API_KEY=                       # chamadas internas web->api se necessário

# ---------- BANCO DE DADOS (Supabase) ---------- [Fase 0]
# Onde pegar: Supabase > Project Settings > Database > Connection string
# DATABASE_URL = "Connection pooling" (porta 6543); DIRECT_URL = "Direct connection" (porta 5432, migrations).
DATABASE_URL=
DIRECT_URL=

# ---------- STORAGE (Supabase Storage) ---------- [Fase 2]
# Onde pegar: Supabase > Project Settings > API. Crie o bucket "tribohub" em Storage.
SUPABASE_URL=                           # Project URL (https://<ref>.supabase.co)
SUPABASE_SERVICE_ROLE_KEY=             # chave service_role — usar SOMENTE no backend
SUPABASE_STORAGE_BUCKET=tribohub

# ---------- E-MAIL (Resend) ---------- [Fase 1]
# Onde pegar: resend.com > API Keys. Verifique o domínio (DNS no Cloudflare).
RESEND_API_KEY=
EMAIL_FROM=Tribo Hub <no-reply@tribohub.com.br>

# ---------- INTEGRAÇÃO HOTMART (webhook) ---------- [Fase 5]
# Conta de teste em developers.hotmart.com. O "hottok"/secret valida o webhook.
HOTMART_WEBHOOK_SECRET=
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=

# ---------- INTEGRAÇÕES EXTRAS (depois da Hotmart) ---------- [Fase 5+]
EDUZZ_API_KEY=
EDUZZ_WEBHOOK_SECRET=
KIWIFY_WEBHOOK_SECRET=

# ---------- COBRANÇA DOS CLIENTES (Efí / ex-Gerencianet) ---------- [Fase 6]
# Onde pegar: sejaefi.com.br > API > Aplicações (Client ID/Secret). Pix exige certificado (.p12/.pem).
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERTIFICATE_PATH=./certs/efi.p12    # arquivo do certificado (NÃO versionar)
EFI_PIX_KEY=                            # chave Pix de recebimento
EFI_SANDBOX=true                        # true (homologação) | false (produção)

# ---------- VÍDEO NATIVO (opcional, fase posterior) ---------- [Fase 5+]
CLOUDFLARE_STREAM_TOKEN=
PANDA_API_KEY=

# ---------- IA — produção de conteúdo (opcional) ---------- [opcional]
# Onde pegar: console.anthropic.com
ANTHROPIC_API_KEY=

# ---------- OBSERVABILIDADE / FILAS (opcional) ---------- [Fase 7 / opcional]
SENTRY_DSN=
REDIS_URL=                              # Upstash, se for usar fila para webhooks
